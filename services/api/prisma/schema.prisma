generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  platform_admin
  customer
}

enum DeviceStatus {
  offline
  online
  fault
}

enum IrrigationCommandStatus {
  queued
  acked
  running
  completed
  failed
  timed_out
}

enum VideoMode {
  webrtc
  mjpeg
}

enum IrrigationScheduleType {
  one_time
  daily
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         UserRole
  customerId   String?
  customer     Customer?  @relation(fields: [customerId], references: [id])
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
}

model Customer {
  id          String             @id @default(cuid())
  name        String
  contactEmail String
  users       User[]
  assignments DeviceAssignment[]
  shareLinks  CustomerShareLink[]
  createdAt   DateTime           @default(now())
}

model Device {
  id                  String                @id
  displayName         String
  location            String
  deviceSecretHash    String                @default("provision-later")
  status              DeviceStatus          @default(offline)
  irrigationState     String                @default("off")
  irrigationRemainingSec Int?
  lastSeenAt          DateTime?
  mjpegStreamUrl       String?
  mqttStatusTopic      String
  mqttEventsTopic      String
  layout              DeviceLayout?
  plotCard            PlotCard?
  assignments         DeviceAssignment[]
  videoSessions       VideoSession[]
  irrigationCommands  IrrigationCommand[]
  irrigationSchedules  IrrigationSchedule[]
  shareLinks          CustomerShareLink[]
  auditLogs           AuditLog[]
  createdAt           DateTime              @default(now())
}

model DeviceLayout {
  deviceId  String   @id
  title     String
  xPct      Float
  yPct      Float
  widthPct  Float
  heightPct Float
  zIndex    Int
  updatedAt DateTime @updatedAt
  device    Device   @relation(fields: [deviceId], references: [id])
}

model PlotCard {
  id        String   @id @default(cuid())
  title     String
  subtitle  String?
  deviceId  String?  @unique
  xPct      Float
  yPct      Float
  widthPct  Float
  heightPct Float
  zIndex    Int
  updatedAt DateTime @updatedAt
  device    Device?  @relation(fields: [deviceId], references: [id])
}

model DeviceAssignment {
  id         String   @id @default(cuid())
  customerId String
  deviceId   String
  customer   Customer @relation(fields: [customerId], references: [id])
  device     Device   @relation(fields: [deviceId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([customerId, deviceId])
}

model VideoSession {
  id          String    @id @default(cuid())
  actorUserId String
  deviceId    String
  mode        VideoMode
  signalingTopic String
  mjpegUrl    String?
  device      Device    @relation(fields: [deviceId], references: [id])
  createdAt   DateTime  @default(now())
  closedAt    DateTime?
}

model IrrigationCommand {
  id            String                   @id @default(cuid())
  actorUserId   String
  deviceId      String
  durationSec   Int
  status        IrrigationCommandStatus
  commandTopic  String
  requestedAt   DateTime                 @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  failureReason String?
  device        Device                   @relation(fields: [deviceId], references: [id])
}

model IrrigationSchedule {
  id            String                 @id @default(cuid())
  actorUserId   String
  deviceId      String
  type          IrrigationScheduleType
  durationSec   Int
  timezone      String                 @default("Asia/Shanghai")
  runAt         DateTime?
  timeOfDay     String?
  nextRunAt     DateTime
  enabled       Boolean                @default(true)
  lastRunAt     DateTime?
  failureReason String?
  device        Device                 @relation(fields: [deviceId], references: [id])
  createdAt     DateTime               @default(now())
}

model CustomerShareLink {
  id              String    @id @default(cuid())
  customerId      String
  deviceId        String?
  tokenHash       String    @unique
  createdByUserId String
  expiresAt       DateTime
  revokedAt       DateTime?
  customer        Customer  @relation(fields: [customerId], references: [id])
  device          Device?   @relation(fields: [deviceId], references: [id])
  createdAt       DateTime  @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  deviceId    String?
  metadata    Json
  actor       User     @relation(fields: [actorUserId], references: [id])
  device      Device?  @relation(fields: [deviceId], references: [id])
  createdAt   DateTime @default(now())
}
