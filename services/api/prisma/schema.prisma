generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  platform_admin
  customer
}

enum DeviceStatus {
  offline
  online
  fault
}

enum IrrigationCommandStatus {
  queued
  acked
  running
  completed
  failed
  timed_out
}

enum VideoMode {
  webrtc
  mjpeg
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         UserRole
  customerId   String?
  customer     Customer?  @relation(fields: [customerId], references: [id])
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
}

model Customer {
  id          String             @id @default(cuid())
  name        String
  contactEmail String
  users       User[]
  assignments DeviceAssignment[]
  createdAt   DateTime           @default(now())
}

model Device {
  id                  String                @id
  displayName         String
  location            String
  deviceSecretHash    String
  status              DeviceStatus          @default(offline)
  irrigationState     String                @default("off")
  lastSeenAt          DateTime?
  assignments         DeviceAssignment[]
  videoSessions       VideoSession[]
  irrigationCommands  IrrigationCommand[]
  auditLogs           AuditLog[]
  createdAt           DateTime              @default(now())
}

model DeviceAssignment {
  id         String   @id @default(cuid())
  customerId String
  deviceId   String
  customer   Customer @relation(fields: [customerId], references: [id])
  device     Device   @relation(fields: [deviceId], references: [id])
  createdAt  DateTime @default(now())

  @@unique([customerId, deviceId])
}

model VideoSession {
  id          String    @id @default(cuid())
  actorUserId String
  deviceId    String
  mode        VideoMode
  signalingTopic String
  mjpegUrl    String?
  device      Device    @relation(fields: [deviceId], references: [id])
  createdAt   DateTime  @default(now())
  closedAt    DateTime?
}

model IrrigationCommand {
  id            String                   @id @default(cuid())
  actorUserId   String
  deviceId      String
  durationSec   Int
  status        IrrigationCommandStatus
  commandTopic  String
  requestedAt   DateTime                 @default(now())
  startedAt     DateTime?
  completedAt   DateTime?
  failureReason String?
  device        Device                   @relation(fields: [deviceId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  deviceId    String?
  metadata    Json
  actor       User     @relation(fields: [actorUserId], references: [id])
  device      Device?  @relation(fields: [deviceId], references: [id])
  createdAt   DateTime @default(now())
}
