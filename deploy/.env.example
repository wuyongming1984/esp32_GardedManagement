POSTGRES_USER=nursery
POSTGRES_PASSWORD=change-me
POSTGRES_DB=nursery
DATABASE_URL=postgresql://nursery:change-me@postgres:5432/nursery
JWT_SECRET=replace-with-strong-random-secret
ADMIN_INITIAL_PASSWORD=change-me-now
MQTT_URL=mqtt://emqx:1883
MQTT_USERNAME=
MQTT_PASSWORD=
TURN_REALM=nursery.example.com
TURN_SECRET=replace-with-turn-secret
PUBLIC_APP_URL=https://nursery.example.com

# Optional: set these on servers that cannot pull Docker Hub directly.
# Example prefix mirrors may change over time; keep these empty unless needed.
POSTGRES_IMAGE=postgres:16
EMQX_IMAGE=emqx/emqx:5
MOSQUITTO_IMAGE=eclipse-mosquitto:2
COTURN_IMAGE=coturn/coturn:4
NGINX_IMAGE=nginx:1.27-alpine
NODE_IMAGE=node:22-bookworm-slim
